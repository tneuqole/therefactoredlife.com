---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header class="border-b border-stone-200">
	<nav class="max-w-2xl mx-auto px-6 py-4 flex items-center justify-between">
		<a
			href="/"
			class="text-stone-900 font-semibold text-sm tracking-wide no-underline hover:text-stone-500 transition-colors"
		>
			{SITE_TITLE}
		</a>
		<div class="flex gap-6">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
